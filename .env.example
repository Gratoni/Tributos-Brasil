# ─── Variáveis de ambiente — Tributos Brasil ───────────────────────────────────
# Copie este arquivo para .env.local (nunca versione .env.local no git).
#
# Todas as variáveis abaixo são usadas pela função serverless api/contact.js.
# Configure-as no painel de Settings > Environment Variables do seu projeto Vercel.

# ── Email (Resend) ──────────────────────────────────────────────────────────────
# Crie uma conta gratuita em https://resend.com e gere uma API Key.
# O plano gratuito permite 3 000 e-mails/mês.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endereço de destino dos formulários de contato
CONTACT_TO=contato@tributosbrasil.com.br

# Endereço remetente (deve estar verificado no painel do Resend)
CONTACT_FROM=Tributos Brasil <no-reply@tributosbrasil.com.br>

# ── CORS ────────────────────────────────────────────────────────────────────────
# Domínio de produção do site (sem barra final)
# A função rejeita requisições de origens não autorizadas.
ALLOWED_ORIGIN=https://tributosbrasil.com.br

# ── Rate limiting (anti-spam / anti-abuse) ─────────────────────────────────────
# Janela de contagem por IP (em segundos) e número máximo de envios por janela.
# Valores padrão: 5 envios a cada 60 segundos por IP.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60
